# ============================================================
# Care Kutumba FE — environment configuration
# ============================================================
# All values below come from your CARE backend. Tag IDs are from
# /api/v1/tag_config/ and identifier config IDs are from the patient
# identifier configuration. Leave blank to disable that mapping.
#
# Currently in production:
#   Only the following are persisted to the patient record:
#     - Ration card tag (BPL / APL) derived from Kutumba rc_type
#     - Ration card number as a patient identifier
#
#   Other Kutumba fields (Health ID, Education ID, etc.) are wired in
#   code but only persisted if their corresponding env IDs below are
#   set. Leave them blank to keep them out of production behavior.
#
# Optional / behavior:
#   - Auto-submit the registration form after fill
# ============================================================

# --- Ration card tag mapping (used by registration + sync) ---
# Kutumba rc_type → CARE tag:
#   BPL, PHH  → REACT_KUTUMBA_BPL_TAG_ID
#   APL, NPHH → REACT_KUTUMBA_APL_TAG_ID
REACT_KUTUMBA_BPL_TAG_ID=
REACT_KUTUMBA_APL_TAG_ID=

# --- Identifier mapping (used by registration + sync) ---
# Maps Kutumba member fields to CARE patient identifier configs.
REACT_KUTUMBA_RC_NUMBER_IDENTIFIER_ID=
REACT_KUTUMBA_HEALTH_ID_IDENTIFIER_ID=
REACT_KUTUMBA_EDUCATION_ID_IDENTIFIER_ID=

# --- Behavior flags ---
# Auto-submit the registration form after filling from Kutumba.
# Set to "true" to enable; disabled by default.
REACT_KUTUMBA_AUTO_SUBMIT_ON_FILL=false

# ============================================================
# Exploratory / not used in production
# ============================================================
# These were added during exploration but are NOT currently used in
# production. Leave blank unless you intentionally enable the related
# code paths. They are also not surfaced in the patient sync preview
# dialog — only ration card tag changes are.
REACT_KUTUMBA_STUDENT_UNVERIFIED_TAG_ID=
REACT_KUTUMBA_PWD_UNVERIFIED_TAG_ID=

# ============================================================
# Planned / not yet supported
# ============================================================
# The following Kutumba fields are received but not yet wired to
# tag/identifier mappings. Add envs here as they get supported:
#   - caste                     → potential tag mapping
#   - disability_applicant_no   → potential identifier mapping
#   - kutumba_id_status         → potential tag/status mapping
#   - rch_id                    → potential identifier mapping
# ============================================================
